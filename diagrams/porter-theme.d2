vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 200
    dark-theme-id: 200
    pad: 24
    sketch: false
  }
}

classes: {
  hub: {
    style: {
      fill: "#111827"
      stroke: "#2563EB"
      color: "#E5E7EB"
      stroke-width: 2
      shadow: true
      border-radius: 10
    }
  }
  node: {
    style: {
      fill: "#0B1220"
      stroke: "#334155"
      color: "#E2E8F0"
      stroke-width: 1
      border-radius: 10
    }
  }
  data: {
    style: {
      fill: "#0F172A"
      stroke: "#0F766E"
      color: "#E2E8F0"
      stroke-width: 1
      border-radius: 10
    }
  }
  lane: {
    style: {
      fill: "#020617"
      stroke: "#1E293B"
      color: "#94A3B8"
      border-radius: 10
    }
  }
}
