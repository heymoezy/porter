title: Porter + OpenClaw Closed-Loop System Map

Direction: right

Operator: {
  label: "Operator Surfaces"
  shape: rectangle
  class: lane

  OpenClawUI: "OpenClaw Interface\nIntent orchestration"
  PorterUI: "Porter UI\nControl plane"
  Locations: "Locations\nMesh/device topology"
  Projects: "Projects\nScope boundary"
}

Runtime: {
  label: "Runtime Control Loop"
  shape: rectangle
  class: lane

  User: "User / Operator"
  OpenClaw: "OpenClaw\nIntent routing"
  PorterHub: "Porter Hub\nPolicy • Audit • Memory scope\nFile transport hub"
  Agents: "Model Agents\nClaude • Gemini • Codex"

  Memory: "Project Memory Layer\nGlobal + Project + Agent override"
  Data: "Files / Data Layer\nRemote FS • Artifacts • Checkpoints"
}

Legend: {
  label: "Meaning"
  shape: rectangle
  class: lane

  L1: "Primary control flow"
  L2: "File transport path"
  L3: "Feedback loop"
  Note: "Porter is memory + governance + transport hub"
}

Runtime.PorterHub.class: hub
Runtime.User.class: node
Runtime.OpenClaw.class: node
Runtime.Agents.class: node
Runtime.Memory.class: data
Runtime.Data.class: data
Operator.OpenClawUI.class: node
Operator.PorterUI.class: node
Operator.Locations.class: node
Operator.Projects.class: node
Legend.L1.class: node
Legend.L2.class: node
Legend.L3.class: node
Legend.Note.class: data

Runtime.User -> Runtime.OpenClaw: "intent"
Runtime.OpenClaw -> Runtime.PorterHub: "orchestration"
Runtime.PorterHub -> Runtime.Agents: "dispatch (PEP/1)"
Runtime.Agents -> Runtime.Data: "read/write"
Runtime.PorterHub -> Runtime.Memory: "scope + memory updates"
Runtime.Data -> Runtime.PorterHub: "execution outcomes"
Runtime.Memory -> Runtime.PorterHub: "context feedback"
Runtime.PorterHub -> Runtime.OpenClaw: "policy/context feedback"

Operator.OpenClawUI -> Runtime.OpenClaw: "configure"
Operator.PorterUI -> Runtime.PorterHub: "govern"
Operator.Locations -> Runtime.PorterHub: "network state"
Operator.Projects -> Runtime.Memory: "project scope"
