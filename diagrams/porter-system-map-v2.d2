vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 200
    dark-theme-id: 200
    pad: 20
    sketch: false
  }
}

classes: {
  lane: {
    style: { fill: "#020617"; stroke: "#1E293B"; border-radius: 10 }
  }
  node: {
    style: { fill: "#0B1220"; stroke: "#334155"; border-radius: 10 }
  }
  hub: {
    style: { fill: "#111827"; stroke: "#2563EB"; stroke-width: 2; border-radius: 10; shadow: true }
  }
  data: {
    style: { fill: "#0F172A"; stroke: "#0F766E"; border-radius: 10 }
  }
  guard: {
    style: { fill: "#1F2937"; stroke: "#F59E0B"; border-radius: 10 }
  }
}

title: Porter v2 Target Architecture (Fresh-Start + Closed Loop)
direction: down

L1: {
  label: "1) Operator & Intent"
  class: lane
  User: "User / Operator\nGoals · approvals"
  OpenClaw: "OpenClaw Orchestrator\nIntent routing · automation"
}

L2: {
  label: "2) First-Run Onboarding & Capability Detection"
  class: lane
  Bootstrap: "Setup Wizard\nFresh install baseline\nNo machine assumptions"
  Registry: "Capability Registry\nDetect runtime + binaries\n(local / VPS / container)"
  Status: "Feature Status Matrix\navailable · unavailable\ninstall guidance"
}

L3: {
  label: "3) Control Plane (Porter)"
  class: lane
  Porter: "Porter Control Core\nPolicy · Audit · Agent lifecycle\nMemory scoping"
  Locations: "Locations Service\nMesh topology · endpoint health"
  Guards: "Loop Guards\nCorrelation IDs · idempotency keys\nmax hop / circuit breaker"
}

L4: {
  label: "4) Execution & Data Path"
  class: lane
  Agents: "Agent Pool\nClaude · Gemini · Codex"
  Router: "Execution Router\nSelect host by capability"
  Transfer: "Transfer Path\nPEP/1 ops over Tailscale"
  Files: "Files / Artifacts\nRemote FS · checkpoints"
}

L5: {
  label: "5) Memory Scopes"
  class: lane
  Memory: "Memory Resolver\nGlobal → Project → Session/User → Agent"
  Projects: "Project Scope Registry\nsettings · ownership · isolation"
}

L1.User.class: node
L1.OpenClaw.class: node
L2.Bootstrap.class: node
L2.Registry.class: data
L2.Status.class: guard
L3.Porter.class: hub
L3.Locations.class: node
L3.Guards.class: guard
L4.Agents.class: node
L4.Router.class: node
L4.Transfer.class: data
L4.Files.class: data
L5.Memory.class: data
L5.Projects.class: node

# Primary control flow
L1.User -> L1.OpenClaw: "intent"
L1.OpenClaw -> L2.Bootstrap: "first-run / config intent"
L2.Bootstrap -> L2.Registry: "discover capabilities"
L2.Registry -> L2.Status: "derive feature states"
L2.Status -> L3.Porter: "validated runtime profile"
L1.OpenClaw -> L3.Porter: "orchestrate"
L3.Porter -> L4.Agents: "dispatch"
L4.Agents -> L4.Router: "request execution"
L4.Router -> L4.Transfer: "execute on selected host"
L4.Transfer -> L4.Files: "read/write"

# Scope + governance links
L3.Porter -> L5.Memory: "resolve context"
L5.Projects -> L5.Memory: "scope boundary"
L3.Locations -> L3.Porter: "network readiness"
L3.Guards -> L3.Porter: "loop safety"
L2.Registry -> L3.Porter: "capability updates"

# Closed-loop feedback
L4.Files -> L3.Porter: "execution outcomes"
L5.Memory -> L3.Porter: "context feedback"
L3.Porter -> L1.OpenClaw: "policy/context feedback"

# Guardrails / principles
Principles: "Guardrails\nNo hardcoded paths/hosts/ports/binaries\nGraceful degradation when missing deps\nNever fake feature availability"
Principles.class: guard
L2.Status -> Principles: "enforce trust UX"
L3.Porter -> Principles: "runtime policy"

# Infrastructure note
Infra: "Transport substrate: Tailscale tailnet (encrypted identity-aware network)"
Infra.class: lane
L4.Transfer -> Infra: "uses"
