#!/usr/bin/env bash
# Porter pre-commit — release-kit ceremony gate. AUTHORITATIVE (blocks).
#
# This gate used to be a SHADOW gate: it printed "ceremony drift" and exited 0.
# Eight consecutive releases (6.85 → 6.92) bumped backend/package.json without
# adding an entry to backend/src/lib/porter-releases.ts. Nobody noticed, because
# a warning that never blocks is a warning nobody reads — and the post-commit
# announcer kept re-announcing v6.84.0, the last version actually in the feed.
#
# That is the exact failure mode CLAUDE.md names: an invariant encoded as a
# reminder instead of a hook eventually rolls wrong. So it is a hook now.
#
# It blocks a commit that bumps backend/package.json without the matching
# CHANGELOG.md + porter-releases.ts entries. Escape hatch for a genuine
# emergency (logged, not silent):
#
#   SKIP_RELEASE_GATE=1 SKIP_REASON="..." git commit ...
#
# Wire with: git config core.hooksPath deploy/git-hooks
set -uo pipefail
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0

# SECRET SCANNER — first, always, and NOT bypassable by SKIP_RELEASE_GATE.
# heymoezy/porter is PUBLIC. On 2026-07-13 the admin service token was found sitting in 11 of its
# commits, and while fixing that I very nearly committed the live OPENCLAW_TOKEN into the same repo.
# Attention is not a control.
"$HOME/projects/_ops/bin/secret-scan.sh" || exit 1

if [ "${SKIP_RELEASE_GATE:-}" = "1" ]; then
  if [ -z "${SKIP_REASON:-}" ]; then
    echo "[porter-release gate] SKIP_RELEASE_GATE=1 requires SKIP_REASON. REFUSED."
    exit 1
  fi
  mkdir -p "$REPO_ROOT/storage"
  echo "$(date -Is) SKIP_RELEASE_GATE reason=${SKIP_REASON}" >> "$REPO_ROOT/storage/release-audit.log"
  echo "[porter-release gate] BYPASSED (logged): ${SKIP_REASON}"
  exit 0
fi

if ! ( cd "$REPO_ROOT" && npx tsx backend/src/release-kit/cli.ts gate --repo "$REPO_ROOT" ); then
  echo ""
  echo "[porter-release gate] REFUSED — ceremony drift (see above)."
  echo "  A version bump must carry its changelog entry AND its release-feed entry:"
  echo "    backend/package.json           (version)"
  echo "    CHANGELOG.md                   (what changed, for us)"
  echo "    backend/src/lib/porter-releases.ts  (what changed, for Moe — this is what gets announced)"
  echo "    CHECKPOINT.md                  (where we got to)"
  echo ""
  exit 1
fi
exit 0
