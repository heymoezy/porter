# Copy to backend/.env (gitignored). The repo is PUBLIC — never commit the real file.
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/porter

# Vault scopes the memory-injection pipeline reads.
MEMORY_INJECTION_VAULT_SCOPES=ymc.capital

# Optional: path to the grok CLI, if Bridge can't find it on PATH.
PORTER_GROK_PATH=
