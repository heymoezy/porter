# Copy to ~/.config/porter/porter.env and chmod 600. NEVER commit the real file —
# the porter repo is PUBLIC.
#
#   install -m 600 ops/systemd/porter.env.example ~/.config/porter/porter.env
#   $EDITOR ~/.config/porter/porter.env
#
# Porter boots without these (graceful degradation, architecture rule 1); it just
# won't have the privileged integrations.

# Postgres for the brain.
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/porter

# openclaw gateway (WhatsApp/agent channels).
OPENCLAW_TOKEN=

# Gates Porter's privileged API (X-Porter-Service-Token): Bridge agent-message,
# job-executor, release announce. Generate a fresh one, never reuse:
#   openssl rand -hex 32
PORTER_SERVICE_TOKEN=
